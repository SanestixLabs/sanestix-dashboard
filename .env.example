# Copy this file to .env and fill in real values from your Supabase project
# (Project Settings → API). Never commit the real .env file.

# Public — safe to expose to the browser. Used by both client and server code.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Your real deployed URL — used to build the email confirmation link.
# Must be the actual domain, not localhost, or confirmation links will 404.
NEXT_PUBLIC_SITE_URL=https://dashboard.sanestix.com

# Secret — server-only. Never expose this to the browser or commit the real
# value. NOT used by the Next.js app itself — only by scripts/setup-founders.mjs,
# which you run locally (outside the app) to provision the 3 founder accounts.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
